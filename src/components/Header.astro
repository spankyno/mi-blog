---
const nav = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog" },
  { label: "Aitor's Hub", href: "https://aitorhub.vercel.app/", external: true },
  { label: "Contacto", href: "https://aitor-blog-contacto.vercel.app/", external: true },
];
const current = Astro.url.pathname;
---
<header>
  <nav>
    <a href="/" class="logo">Aitor Sánchez Gutiérrez</a>
    <ul>
      {nav.map(({ label, href, external }) => (
        <li>
          <a 
            href={href} 
            class={!external && current.startsWith(href) ? "active" : ""}
            target={external ? "_blank" : undefined}
            rel={external ? "noopener noreferrer" : undefined}
          >{label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    background: #fafaf8ee;
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
    z-index: 100;
  }
  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: -0.02em;
  }
  ul {
    list-style: none;
    display: flex;
    gap: 2rem;
  }
  ul a {
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--color-muted);
    transition: color 0.2s;
  }
  ul a:hover, ul a.active {
    color: var(--color-text);
  }
</style>
