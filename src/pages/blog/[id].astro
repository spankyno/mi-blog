---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={`${post.data.title} — Aitor Sánchez`} description={post.data.description}>
  <Header />
  <main>
    <article>
      <header>
        <p class="date">{post.data.pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        <h1>{post.data.title}</h1>
        <p class="desc">{post.data.description}</p>
      </header>
      <div class="content">
        <Content />
      </div>
    </article>
    <a href="/blog" class="back">← Volver al blog</a>
  </main>
  <Footer />
</Base>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  article { padding: 3rem 0 4rem; }
  header { margin-bottom: 3rem; border-bottom: 1px solid var(--color-border); padding-bottom: 2rem; }
  .date { font-size: 0.875rem; color: var(--color-muted); margin-bottom: 1rem; }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .desc { color: var(--color-muted); font-size: 1.05rem; }
  .content { line-height: 1.8; }
  .content h2 { font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; margin: 2.5rem 0 1rem; }
  .content p { margin-bottom: 1.5rem; }
  .content a { text-decoration: underline; text-underline-offset: 3px; }
  .back { font-size: 0.875rem; color: var(--color-muted); transition: color 0.2s; }
  .back:hover { color: var(--color-text); }
</style>
