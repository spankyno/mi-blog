---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { marked } from 'marked';
import DOMPurify from 'isomorphic-dompurify';

const { slug } = Astro.params;
const db = Astro.locals.runtime?.env?.DB;
let post = null;

if (db) {
  const result = await db.prepare(
    `SELECT * FROM posts WHERE slug = ? AND draft != 1`
  ).bind(slug).first();
  post = result;
}

if (!post) return Astro.redirect('/blog');

if (db) {
  const req = Astro.request;
  const headers = req.headers;
  const ip = headers.get('cf-connecting-ip') ?? headers.get('x-forwarded-for') ?? null;
  const country = headers.get('cf-ipcountry') ?? null;
  const region = headers.get('cf-region') ?? null;
  const city = headers.get('cf-ipcity') ?? null;
  const userAgent = headers.get('user-agent') ?? null;
  const referer = headers.get('referer') ?? null;
  const botPatterns = /bot|crawler|spider|curl|python|wget|scrapy|headless/i;
  const isBot = userAgent ? (botPatterns.test(userAgent) ? 1 : 0) : 0;
  const viewedAt = new Date().toISOString();

  Astro.locals.runtime.ctx.waitUntil(
    db.prepare(
      `INSERT INTO page_views (slug, viewed_at, ip, country, region, city, user_agent, referer, is_bot)
       VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)`
    ).bind(slug, viewedAt, ip, country, region, city, userAgent, referer, isBot).run()
  );
}

const contentHtml = DOMPurify.sanitize(await marked(post.content ?? ''));

const SITE_URL = 'https://aitorsanchez.pages.dev';
const ogImage = post.hero_image?.startsWith('http')
  ? post.hero_image
  : `${SITE_URL}/images/foto-portada.png`;
---
<Base
  title={post.title}
  description={post.description ?? undefined}
  ogType="article"
  ogImage={ogImage}
  pubDate={post.pub_date}
>
  <Header />
  <main>
    <article>
      <header>
        <p class="date">{new Date(post.pub_date).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        <h1>{post.title}</h1>
        <p class="desc">{post.description}</p>
      </header>
      {post.hero_image && <img src={post.hero_image} alt={post.title} class="hero-img" />}
      <div class="content" set:html={contentHtml} />
    </article>
    <a href="/blog" class="back">← Volver al blog</a>
  </main>
  <Footer />
</Base>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  article { padding: 3rem 0 4rem; }
  header { margin-bottom: 2rem; border-bottom: 1px solid var(--color-border); padding-bottom: 2rem; }
  .date { font-size: 0.875rem; color: var(--color-muted); margin-bottom: 1rem; }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .desc { color: var(--color-muted); font-size: 1.05rem; }
  .hero-img { width: 100%; height: 300px; object-fit: cover; margin-bottom: 2rem; }
  .content { line-height: 1.8; }
  .content :global(h2) { font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; margin: 2.5rem 0 1rem; }
  .content :global(h3) { font-size: 1.15rem; font-weight: 500; margin: 2rem 0 0.75rem; }
  .content :global(strong),
  .content :global(b) {
    font-weight: 800 !important;
    color: #000;
  }
  .content :global(p) { margin-bottom: 1.5rem; }
  .content :global(a) { text-decoration: underline; text-underline-offset: 3px; }
  .content :global(ul), .content :global(ol) { padding-left: 1.5rem; margin-bottom: 1.5rem; }
  .content :global(li) { margin-bottom: 0.4rem; }
  .content :global(blockquote) {
    border-left: 3px solid var(--color-border);
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.25rem;
    color: var(--color-muted);
    font-style: italic;
  }
  .content :global(pre) {
    background: #f4f4f2;
    border-radius: 6px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }
  .content :global(code) { font-size: 0.875rem; background: #f4f4f2; padding: 0.15em 0.4em; border-radius: 3px; }
  .content :global(pre code) { background: none; padding: 0; }
  .content :global(img) { max-width: 100%; border-radius: 6px; margin: 1rem 0; }
  .back { font-size: 0.875rem; color: var(--color-muted); transition: color 0.2s; }
  .back:hover { color: var(--color-text); }
</style>
