---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const db = Astro.locals.runtime?.env?.DB;
let posts = [];

if (db) {
  const postsResult = await db.prepare(
    `SELECT slug, title, description, pub_date, hero_image FROM posts WHERE draft != 1 ORDER BY pub_date DESC LIMIT 4`
  ).all();
  posts = postsResult.results ?? [];
}
---
<Base title="Aitor Sánchez Gutiérrez">
  <Header />

  <section class="hero">
    <img src="/images/foto-portada.png" alt="Aitor Sánchez" />
  </section>

  <main>
    <section class="section">
      <div class="section-header">
        <h2>Últimas entradas</h2>
        <a href="/blog" class="see-all">Ver todas →</a>
      </div>
      <ul class="list">
        {posts.map((post: any) => (
          <li>
            <a href={`/blog/${post.slug}`} class="post-link">
              <div class="post-thumb">
                {post.hero_image
                  ? <img src={post.hero_image} alt={post.title} />
                  : <div class="post-thumb-placeholder">{post.title.charAt(0)}</div>
                }
              </div>
              <div class="post-info">
                <span class="post-title">{post.title}</span>
                {post.description && <span class="post-desc">{post.description}</span>}
              </div>
              <span class="post-date">{new Date(post.pub_date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            </a>
          </li>
        ))}
        {posts.length === 0 && <li class="empty">Próximamente…</li>}
      </ul>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .hero {
    width: 100%;
    margin-bottom: 3rem;
    line-height: 0;
  }
  .hero img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 480px;
    object-fit: cover;
    object-position: center top;
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  .section { margin-bottom: 4rem; }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.25rem;
  }
  .section-header h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
  }
  .see-all { font-size: 0.875rem; color: var(--color-muted); transition: color 0.2s; }
  .see-all:hover { color: var(--color-text); }
  .list { list-style: none; }
  .list li { border-top: 1px solid var(--color-border); }
  .list li:last-child { border-bottom: 1px solid var(--color-border); }
  .post-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 0;
    transition: opacity 0.2s;
  }
  .post-link:hover { opacity: 0.6; }
  .post-thumb {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-border);
  }
  .post-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .post-thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-muted);
  }
  .post-info { flex: 1; display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .post-title { font-weight: 400; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .post-desc { font-size: 0.825rem; color: var(--color-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .post-date { font-size: 0.8rem; color: var(--color-muted); white-space: nowrap; flex-shrink: 0; }
  .empty { padding: 1rem 0; color: var(--color-muted); font-size: 0.9rem; border-top: 1px solid var(--color-border); }

  @media (max-width: 500px) {
    .post-date { display: none; }
  }
</style>
