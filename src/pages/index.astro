---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const db = Astro.locals.runtime?.env?.DB;

let posts = [];
let proyectos = [];

if (db) {
  const postsResult = await db.prepare(
    `SELECT slug, title, description, pub_date FROM posts WHERE draft = 0 ORDER BY pub_date DESC LIMIT 3`
  ).all();
  posts = postsResult.results ?? [];

  const portfolioResult = await db.prepare(
    `SELECT slug, title, description FROM portfolio ORDER BY pub_date DESC LIMIT 3`
  ).all();
  proyectos = portfolioResult.results ?? [];
}
---
<Base title="Aitor Sánchez">
  <Header />
  <main>
    <section class="hero">
      <div class="hero-cover">
        <img src="/images/foto-portada.png" alt="Aitor Sánchez" />
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Últimas entradas</h2>
        <a href="/blog">Ver todas →</a>
      </div>
      <ul class="list">
        {posts.map((post: any) => (
          <li>
            <a href={`/blog/${post.slug}`} class="post-link">
              <span class="post-title">{post.title}</span>
              <span class="post-date">{new Date(post.pub_date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            </a>
          </li>
        ))}
        {posts.length === 0 && <li class="empty">Próximamente…</li>}
      </ul>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Portfolio</h2>
        <a href="https://aitorhub.vercel.app/" target="_blank" rel="noopener">Ver todo →</a>
      </div>
      <ul class="list">
        {proyectos.map((p: any) => (
          <li>
            <a href={`/portfolio/${p.slug}`} class="post-link">
              <span class="post-title">{p.title}</span>
              <span class="post-date">{p.description}</span>
            </a>
          </li>
        ))}
        {proyectos.length === 0 && <li class="empty">Próximamente…</li>}
      </ul>
    </section>
  </main>
  <Footer />
</Base>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .hero { margin-bottom: 4rem; }
  .hero-cover {
    width: calc(100% + 3rem);
    margin-left: -1.5rem;
    height: clamp(200px, 40vw, 360px);
    overflow: hidden;
  }
  .hero-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .section { margin-bottom: 4rem; }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }
  .section-header h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
  }
  .section-header a {
    font-size: 0.875rem;
    color: var(--color-muted);
    transition: color 0.2s;
  }
  .section-header a:hover { color: var(--color-text); }
  .list { list-style: none; }
  .list li { border-top: 1px solid var(--color-border); }
  .list li:last-child { border-bottom: 1px solid var(--color-border); }
  .post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 1rem 0;
    transition: opacity 0.2s;
  }
  .post-link:hover { opacity: 0.6; }
  .post-title { font-weight: 400; }
  .post-date { font-size: 0.85rem; color: var(--color-muted); white-space: nowrap; }
  .empty { padding: 1rem 0; color: var(--color-muted); font-size: 0.9rem; border-top: 1px solid var(--color-border); }
</style>
