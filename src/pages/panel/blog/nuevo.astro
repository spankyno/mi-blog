---
import Base from '../../../layouts/Base.astro';

if (Astro.request.method === 'POST') {
  const db = Astro.locals.runtime?.env?.DB;
  const form = await Astro.request.formData();

  const title = form.get('title') as string;
  const slug = form.get('slug') as string;
  const description = form.get('description') as string;
  const content = form.get('content') as string;
  const hero_image = form.get('hero_image') as string;
  const tags = form.get('tags') as string;
  const draft = form.get('draft') === 'on' ? 1 : 0;
  const pub_date = form.get('pub_date') as string;

  const tagsJson = JSON.stringify(tags.split(',').map((t: string) => t.trim()).filter(Boolean));

  await db.prepare(
    `INSERT INTO posts (slug, title, description, content, hero_image, tags, draft, pub_date) VALUES (?, ?, ?, ?, ?, ?, ?, ?)`
  ).bind(slug, title, description, content, hero_image, tagsJson, draft, pub_date).run();

  return Astro.redirect('/panel');
}

const today = new Date().toISOString().split('T')[0];
---
<Base title="Nuevo post — Admin">
  <main>
    <header class="topbar">
      <a href="/panel" class="back">← Admin</a>
      <span class="topbar-title">Nuevo post</span>
    </header>

    <div class="container">
      <form method="POST" class="form">
        <div class="form-group">
          <label for="title">Título</label>
          <input type="text" id="title" name="title" required />
        </div>

        <div class="form-group">
          <label for="slug">Slug <span class="hint">(URL: /blog/mi-post)</span></label>
          <input type="text" id="slug" name="slug" required placeholder="mi-primer-post" />
        </div>

        <div class="form-group">
          <label for="description">Descripción</label>
          <input type="text" id="description" name="description" />
        </div>

        <div class="form-group">
          <label for="pub_date">Fecha de publicación</label>
          <input type="date" id="pub_date" name="pub_date" value={today} required />
        </div>

        <div class="form-group">
          <label for="hero_image">URL imagen destacada</label>
          <input type="text" id="hero_image" name="hero_image" placeholder="https://..." />
        </div>

        <div class="form-group">
          <label for="tags">Tags <span class="hint">(separados por comas)</span></label>
          <input type="text" id="tags" name="tags" placeholder="tecnología, diseño" />
        </div>

        <div class="form-group">
          <label for="content">Contenido <span class="hint">(HTML)</span></label>
          <textarea id="content" name="content" rows="20"></textarea>
        </div>

        <div class="form-check">
          <input type="checkbox" id="draft" name="draft" />
          <label for="draft">Guardar como borrador</label>
        </div>

        <div class="form-actions">
          <a href="/panel" class="btn-cancel">Cancelar</a>
          <button type="submit" class="btn-save">Guardar post</button>
        </div>
      </form>
    </div>
  </main>
</Base>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --font-body: 'DM Sans', sans-serif;
    --color-bg: #fafaf8;
    --color-text: #1a1a18;
    --color-muted: #6b6b67;
    --color-border: #e5e5e0;
  }
  main { font-family: var(--font-body); background: var(--color-bg); min-height: 100vh; color: var(--color-text); font-weight: 300; }
  .topbar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid var(--color-border);
    background: #fafaf8ee;
    position: sticky;
    top: 0;
    backdrop-filter: blur(8px);
  }
  .back { font-size: 0.875rem; color: var(--color-muted); text-decoration: none; transition: color 0.2s; }
  .back:hover { color: var(--color-text); }
  .topbar-title { font-size: 0.9rem; color: var(--color-muted); }
  .container { max-width: 720px; margin: 0 auto; padding: 3rem 2rem; }
  .form { display: flex; flex-direction: column; gap: 1.5rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  label { font-size: 0.875rem; font-weight: 400; }
  .hint { color: var(--color-muted); font-weight: 300; }
  input[type="text"], input[type="date"], textarea {
    padding: 0.65rem 0.875rem;
    border: 1px solid var(--color-border);
    background: white;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  input:focus, textarea:focus { border-color: var(--color-text); }
  textarea { resize: vertical; line-height: 1.6; }
  .form-check { display: flex; align-items: center; gap: 0.75rem; }
  .form-check input { width: auto; }
  .form-check label { font-size: 0.875rem; margin: 0; }
  .form-actions { display: flex; gap: 1rem; justify-content: flex-end; padding-top: 1rem; border-top: 1px solid var(--color-border); }
  .btn-cancel {
    padding: 0.65rem 1.25rem;
    font-size: 0.875rem;
    text-decoration: none;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    transition: all 0.2s;
  }
  .btn-cancel:hover { border-color: var(--color-text); color: var(--color-text); }
  .btn-save {
    padding: 0.65rem 1.5rem;
    font-size: 0.875rem;
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    transition: opacity 0.2s;
  }
  .btn-save:hover { opacity: 0.75; }
</style>

<script>
  // Auto-generar slug desde el título
  const titleInput = document.getElementById('title');
  const slugInput = document.getElementById('slug');
  let slugManuallyEdited = false;

  slugInput?.addEventListener('input', () => { slugManuallyEdited = true; });

  titleInput?.addEventListener('input', () => {
    if (!slugManuallyEdited) {
      const slug = titleInput.value
        .toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-');
      slugInput.value = slug;
    }
  });
</script>
