---
import Base from '../../../layouts/Base.astro';

const { slug } = Astro.params;
const db = Astro.locals.runtime?.env?.DB;
let post: any = null;
let error = '';

if (db) {
  post = await db.prepare(`SELECT * FROM posts WHERE slug = ?`).bind(slug).first();
}

if (!post) return Astro.redirect('/panel');

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const title = (form.get('title') as string)?.trim();
  const newSlug = (form.get('slug') as string)?.trim();
  const description = (form.get('description') as string)?.trim();
  const content = (form.get('content') as string)?.trim();
  const pub_date = form.get('pub_date') as string;
  const draft = form.get('draft') === 'on' ? 1 : 0;

  if (db && title && newSlug) {
    await db.prepare(
      `UPDATE posts SET slug=?, title=?, description=?, content=?, pub_date=?, draft=? WHERE slug=?`
    ).bind(newSlug, title, description, content, pub_date, draft, slug).run();

    return Astro.redirect('/panel');
  }
}
---
<Base title={`Editar: ${post.title} — Panel`}>
  <main>
    <div class="topbar">
      <a href="/panel" class="back">← Volver</a>
      <h1>Editar post</h1>
      <a href={`/blog/${post.slug}`} target="_blank" class="preview">Ver en blog ↗</a>
    </div>

    <form method="POST">
      <div class="row two">
        <label>
          Título
          <input type="text" name="title" required value={post.title} />
        </label>
        <label>
          Slug (URL)
          <input type="text" name="slug" required value={post.slug} pattern="[a-z0-9\-]+" />
        </label>
      </div>

      <label>
        Descripción
        <input type="text" name="description" value={post.description ?? ''} />
      </label>

      <label>
        Contenido <span class="hint">(HTML permitido)</span>
        <textarea name="content" rows="18">{post.content ?? ''}</textarea>
      </label>

      <div class="row two">
        <label>
          Fecha de publicación
          <input type="date" name="pub_date" required value={post.pub_date?.split('T')[0] ?? ''} />
        </label>
        <label class="checkbox-label">
          <input type="checkbox" name="draft" checked={post.draft === 1 || post.draft === true} />
          Borrador
        </label>
      </div>

      <div class="form-footer">
        <button type="submit" class="btn-save">Guardar cambios</button>
      </div>
    </form>
  </main>
</Base>

<style>
  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .topbar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .back { font-size: 0.875rem; color: var(--color-muted); transition: color 0.2s; }
  .back:hover { color: var(--color-text); }
  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    flex: 1;
  }
  .preview { font-size: 0.875rem; color: var(--color-muted); transition: color 0.2s; }
  .preview:hover { color: var(--color-text); }
  form { display: flex; flex-direction: column; gap: 1.5rem; }
  label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
  }
  .hint { font-weight: 400; font-size: 0.8rem; }
  input[type="text"],
  input[type="date"],
  textarea {
    font-family: inherit;
    font-size: 1rem;
    font-weight: 300;
    color: var(--color-text);
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.65rem 0.9rem;
    transition: border-color 0.2s;
    width: 100%;
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--color-text);
  }
  textarea { resize: vertical; font-size: 0.9rem; line-height: 1.6; }
  .row.two { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .checkbox-label {
    flex-direction: row;
    align-items: center;
    gap: 0.6rem;
    padding-top: 1.6rem;
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .checkbox-label input { width: auto; }
  .form-footer { display: flex; justify-content: flex-end; padding-top: 0.5rem; }
  .btn-save {
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    padding: 0.65rem 1.75rem;
    font-size: 0.95rem;
    font-family: inherit;
    border-radius: 6px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .btn-save:hover { opacity: 0.75; }
</style>
