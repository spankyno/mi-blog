---
import Base from '../../layouts/Base.astro';

const db = Astro.locals.runtime?.env?.DB;
let posts = [];

if (db) {
  const result = await db.prepare(
    `SELECT slug, title, pub_date, draft FROM posts ORDER BY pub_date DESC`
  ).all();
  posts = result.results ?? [];
}
---
<Base title="Panel — Aitor Sánchez">
  <main>
    <div class="topbar">
      <h1>Panel</h1>
      <div class="topbar-actions">
        <a href="/blog" target="_blank" class="btn-blog">Ver blog ↗</a>
        <a href="/panel/nuevo" class="btn-new">+ Nuevo post</a>
      </div>
    </div>

    <table>
      <thead>
        <tr>
          <th>Título</th>
          <th>Fecha</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        {posts.map((post: any) => (
          <tr>
            <td>{post.title}</td>
            <td>{new Date(post.pub_date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}</td>
            <td>
              <span class={post.draft ? 'badge draft' : 'badge published'}>
                {post.draft ? 'Borrador' : 'Publicado'}
              </span>
            </td>
            <td class="actions">
              <a href={`/panel/editar/${post.slug}`} class="btn-edit">Editar</a>
              <button
                class="btn-delete"
                data-slug={post.slug}
                onclick="deletePost(this)"
              >Borrar</button>
            </td>
          </tr>
        ))}
        {posts.length === 0 && (
          <tr><td colspan="4" class="empty">No hay posts todavía.</td></tr>
        )}
      </tbody>
    </table>
  </main>
</Base>

<script>
  async function deletePost(btn: HTMLButtonElement) {
    const slug = btn.dataset.slug;
    if (!confirm(`¿Borrar "${slug}"? Esta acción no se puede deshacer.`)) return;

    const res = await fetch('/api/panel/posts', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug }),
    });

    if (res.ok) {
      btn.closest('tr')?.remove();
    } else {
      alert('Error al borrar el post.');
    }
  }
  (window as any).deletePost = deletePost;
</script>

<style>
  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
  .topbar-actions { display: flex; gap: 0.75rem; align-items: center; }
  .btn-blog {
    font-size: 0.9rem;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-blog:hover { color: var(--color-text); border-color: var(--color-text); }
  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  .btn-new {
    background: var(--color-text);
    color: var(--color-bg);
    padding: 0.5rem 1.25rem;
    font-size: 0.9rem;
    border-radius: 4px;
    transition: opacity 0.2s;
  }
  .btn-new:hover { opacity: 0.75; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  th {
    text-align: left;
    font-weight: 500;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  td {
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: middle;
  }
  tr:hover td { background: #f5f5f2; }

  .badge {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    font-weight: 500;
  }
  .badge.published { background: #d1fae5; color: #065f46; }
  .badge.draft { background: #fef3c7; color: #92400e; }

  .actions { display: flex; gap: 0.5rem; }
  .btn-edit, .btn-delete {
    font-size: 0.8rem;
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: transparent;
    font-family: inherit;
    transition: background 0.15s;
  }
  .btn-edit { color: var(--color-text); text-decoration: none; }
  .btn-edit:hover { background: var(--color-border); }
  .btn-delete { color: #dc2626; border-color: #fca5a5; }
  .btn-delete:hover { background: #fee2e2; }

  .empty { color: var(--color-muted); padding: 2rem 1rem; }
</style>
