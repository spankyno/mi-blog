---
import Base from '../../layouts/Base.astro';

const db = Astro.locals.runtime?.env?.DB;
let posts = [];
let proyectos = [];

if (db) {
  const postsResult = await db.prepare(
    `SELECT id, slug, title, draft, pub_date FROM posts ORDER BY pub_date DESC`
  ).all();
  posts = postsResult.results ?? [];

  const portfolioResult = await db.prepare(
    `SELECT id, slug, title, pub_date FROM portfolio ORDER BY pub_date DESC`
  ).all();
  proyectos = portfolioResult.results ?? [];
}
---
<Base title="Admin — Aitor Sánchez">
  <main>
    <header class="topbar">
      <a href="/" class="logo">AS</a>
      <span class="topbar-title">Panel de administración</span>
    </header>

    <div class="container">
      <!-- BLOG -->
      <section class="panel">
        <div class="panel-header">
          <h2>Blog</h2>
          <a href="/panel/blog/nuevo" class="btn-new">+ Nuevo post</a>
        </div>
        <ul class="item-list">
          {posts.map((post: any) => (
            <li class="item">
              <div class="item-info">
                <span class="item-title">{post.title}</span>
                <span class="item-meta">
                  {post.draft ? <span class="badge draft">Borrador</span> : <span class="badge published">Publicado</span>}
                  <span class="item-date">{new Date(post.pub_date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                </span>
              </div>
              <div class="item-actions">
                <a href={`/panel/blog/editar/${post.id}`} class="btn-edit">Editar</a>
                <a href={`/blog/${post.slug}`} target="_blank" class="btn-view">Ver</a>
              </div>
            </li>
          ))}
          {posts.length === 0 && <li class="empty">No hay posts todavía.</li>}
        </ul>
      </section>

      <!-- PORTFOLIO -->
      <section class="panel">
        <div class="panel-header">
          <h2>Portfolio</h2>
          <a href="/panel/portfolio/nuevo" class="btn-new">+ Nuevo proyecto</a>
        </div>
        <ul class="item-list">
          {proyectos.map((p: any) => (
            <li class="item">
              <div class="item-info">
                <span class="item-title">{p.title}</span>
                <span class="item-meta">
                  <span class="item-date">{new Date(p.pub_date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                </span>
              </div>
              <div class="item-actions">
                <a href={`/panel/portfolio/editar/${p.id}`} class="btn-edit">Editar</a>
                <a href={`/portfolio/${p.slug}`} target="_blank" class="btn-view">Ver</a>
              </div>
            </li>
          ))}
          {proyectos.length === 0 && <li class="empty">No hay proyectos todavía.</li>}
        </ul>
      </section>
    </div>
  </main>
</Base>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --font-display: 'DM Serif Display', serif;
    --font-body: 'DM Sans', sans-serif;
    --color-bg: #fafaf8;
    --color-text: #1a1a18;
    --color-muted: #6b6b67;
    --color-border: #e5e5e0;
    --color-accent: #1a1a18;
  }
  main {
    font-family: var(--font-body);
    background: var(--color-bg);
    min-height: 100vh;
    color: var(--color-text);
    font-weight: 300;
  }
  .topbar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid var(--color-border);
    background: #fafaf8ee;
    position: sticky;
    top: 0;
    backdrop-filter: blur(8px);
  }
  .logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    text-decoration: none;
    color: var(--color-text);
  }
  .topbar-title {
    font-size: 0.9rem;
    color: var(--color-muted);
  }
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .panel-header h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
  }
  .btn-new {
    font-size: 0.875rem;
    padding: 0.5rem 1rem;
    background: var(--color-text);
    color: var(--color-bg);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .btn-new:hover { opacity: 0.75; }
  .item-list { list-style: none; }
  .item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
    border-top: 1px solid var(--color-border);
  }
  .item:last-child { border-bottom: 1px solid var(--color-border); }
  .item-info { display: flex; flex-direction: column; gap: 0.3rem; }
  .item-title { font-weight: 400; }
  .item-meta { display: flex; align-items: center; gap: 0.75rem; }
  .item-date { font-size: 0.8rem; color: var(--color-muted); }
  .badge {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }
  .badge.draft { background: #f0f0eb; color: var(--color-muted); }
  .badge.published { background: #e8f5e9; color: #2e7d32; }
  .item-actions { display: flex; gap: 0.75rem; flex-shrink: 0; }
  .btn-edit, .btn-view {
    font-size: 0.8rem;
    padding: 0.35rem 0.75rem;
    text-decoration: none;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    transition: all 0.2s;
  }
  .btn-edit:hover { border-color: var(--color-text); color: var(--color-text); }
  .btn-view:hover { border-color: var(--color-text); color: var(--color-text); }
  .empty { padding: 1rem 0; color: var(--color-muted); font-size: 0.9rem; border-top: 1px solid var(--color-border); }

  @media (max-width: 600px) {
    .item { flex-direction: column; align-items: flex-start; }
    .item-actions { width: 100%; justify-content: flex-start; }
  }
</style>
