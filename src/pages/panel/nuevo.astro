---
import Base from '../../layouts/Base.astro';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const title = (form.get('title') as string)?.trim();
  const slug = (form.get('slug') as string)?.trim();
  const description = (form.get('description') as string)?.trim();
  const content = (form.get('content') as string)?.trim();
  const pub_date = form.get('pub_date') as string;
  const draft = form.get('draft') === 'on' ? 1 : 0;

  const hero_image = (form.get('hero_image') as string)?.trim() || null;
  const db = Astro.locals.runtime?.env?.DB;
  if (db && title && slug) {
    await db.prepare(
      `INSERT INTO posts (slug, title, description, content, pub_date, draft, hero_image)
       VALUES (?, ?, ?, ?, ?, ?, ?)`
    ).bind(slug, title, description, content, pub_date, draft, hero_image).run();

    return Astro.redirect('/panel');
  }
}
---
<Base title="Nuevo post — Panel">
  <link rel="stylesheet" href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css" />

  <main>
    <div class="topbar">
      <a href="/panel" class="back">← Volver</a>
      <h1>Nuevo post</h1>
    </div>

    <form method="POST" id="post-form">
      <div class="row two">
        <label>
          Título
          <input type="text" name="title" required placeholder="Mi primer post" id="title-input" />
        </label>
        <label>
          Slug (URL)
          <input type="text" name="slug" required placeholder="mi-primer-post" pattern="[a-z0-9\-]+" id="slug-input" />
        </label>
      </div>

      <label>
        Descripción
        <input type="text" name="description" placeholder="Un resumen breve del post" />
      </label>

      <div class="image-wrap">
        <label>
          Imagen de cabecera <span class="hint">(URL externa, ej. de Imgur o GitHub)</span>
          <input type="text" name="hero_image" id="hero-image-input" placeholder="https://i.imgur.com/ejemplo.jpg" />
        </label>
        <div id="image-preview" class="image-preview hidden">
          <img id="preview-img" src="" alt="Preview" />
          <button type="button" id="remove-image" class="btn-remove">✕ Quitar imagen</button>
        </div>
      </div>

      <div class="editor-wrap">
        <span class="editor-label">Contenido</span>
        <div id="editor"></div>
        <input type="hidden" name="content" id="content-input" />
      </div>

      <div class="row two">
        <label>
          Fecha de publicación
          <input type="date" name="pub_date" required value={new Date().toISOString().split('T')[0]} />
        </label>
        <label class="checkbox-label">
          <input type="checkbox" name="draft" checked />
          Guardar como borrador
        </label>
      </div>

      <div class="form-footer">
        <button type="submit" class="btn-save">Guardar post</button>
      </div>
    </form>
  </main>
</Base>

<script>
  const script = document.createElement('script');
  script.src = 'https://uicdn.toast.com/editor/latest/toastui-editor-all.min.js';
  script.onload = () => {
    const { Editor } = (window as any).toastui;

    const editor = new Editor({
      el: document.getElementById('editor'),
      height: '480px',
      initialEditType: 'markdown',
      previewStyle: 'vertical',
      placeholder: 'Escribe el contenido del post en Markdown...',
    });

    const titleInput = document.getElementById('title-input') as HTMLInputElement;
    const slugInput = document.getElementById('slug-input') as HTMLInputElement;
    let slugManuallyEdited = false;

    slugInput.addEventListener('input', () => { slugManuallyEdited = true; });
    titleInput.addEventListener('input', () => {
      if (slugManuallyEdited) return;
      slugInput.value = titleInput.value
        .toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9\s-]/g, '')
        .trim()
        .replace(/\s+/g, '-');
    });

    document.getElementById('post-form')?.addEventListener('submit', () => {
      (document.getElementById('content-input') as HTMLInputElement).value = editor.getMarkdown();
    });

    // Previsualización de imagen
    const heroInput = document.getElementById('hero-image-input') as HTMLInputElement;
    const preview = document.getElementById('image-preview') as HTMLDivElement;
    const previewImg = document.getElementById('preview-img') as HTMLImageElement;
    const removeBtn = document.getElementById('remove-image') as HTMLButtonElement;

    function updatePreview(url: string) {
      if (url) {
        previewImg.src = url;
        preview.classList.remove('hidden');
      } else {
        preview.classList.add('hidden');
        previewImg.src = '';
      }
    }

    heroInput.addEventListener('input', () => updatePreview(heroInput.value.trim()));
    removeBtn.addEventListener('click', () => {
      heroInput.value = '';
      updatePreview('');
    });
    previewImg.addEventListener('error', () => preview.classList.add('hidden'));
  };
  document.head.appendChild(script);
</script>

<style>
  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .topbar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .back { font-size: 0.875rem; color: var(--color-muted); transition: color 0.2s; }
  .back:hover { color: var(--color-text); }
  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  form { display: flex; flex-direction: column; gap: 1.5rem; }
  label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
  }
  input[type="text"],
  input[type="date"] {
    font-family: inherit;
    font-size: 1rem;
    font-weight: 300;
    color: var(--color-text);
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.65rem 0.9rem;
    transition: border-color 0.2s;
    width: 100%;
  }
  input:focus { outline: none; border-color: var(--color-text); }
  .image-wrap { display: flex; flex-direction: column; gap: 0.75rem; }
  .image-preview { position: relative; display: inline-block; }
  .image-preview img {
    width: 100%;
    max-height: 240px;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--color-border);
  }
  .image-preview.hidden { display: none; }
  .btn-remove {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgba(0,0,0,0.6);
    color: white;
    border: none;
    border-radius: 4px;
    padding: 0.25rem 0.6rem;
    font-size: 0.8rem;
    cursor: pointer;
    font-family: inherit;
  }
  .btn-remove:hover { background: rgba(0,0,0,0.85); }
  .editor-wrap { display: flex; flex-direction: column; gap: 0.4rem; }
  .editor-label { font-size: 0.875rem; font-weight: 500; color: var(--color-muted); }
  #editor { border: 1px solid var(--color-border); border-radius: 6px; overflow: hidden; }
  .row.two { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .checkbox-label {
    flex-direction: row;
    align-items: center;
    gap: 0.6rem;
    padding-top: 1.6rem;
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .checkbox-label input { width: auto; }
  .form-footer { display: flex; justify-content: flex-end; padding-top: 0.5rem; }
  .btn-save {
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    padding: 0.65rem 1.75rem;
    font-size: 0.95rem;
    font-family: inherit;
    border-radius: 6px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .btn-save:hover { opacity: 0.75; }
</style>
