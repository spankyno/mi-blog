---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import { marked } from 'marked';
import DOMPurify from 'isomorphic-dompurify';

const { slug } = Astro.params;
const db = Astro.locals.runtime?.env?.DB;
let post: any = null;

if (db) {
  post = await db.prepare(`SELECT * FROM posts WHERE slug = ?`).bind(slug).first();
}

if (!post) return Astro.redirect('/panel');

const contentHtml = DOMPurify.sanitize(await marked(post.content ?? ''));
---
<Base title={`Preview: ${post.title}`}>
  <Header />
  <div class="preview-bar">
    <span class="preview-badge">Vista previa {post.draft ? '— Borrador' : '— Publicado'}</span>
    <div class="preview-actions">
      <a href={`/panel/editar/${post.slug}`} class="btn-edit">← Editar</a>
      <a href={`/blog/${post.slug}`} target="_blank" class="btn-live">Ver en blog ↗</a>
    </div>
  </div>
  <main>
    <article>
      <header>
        <p class="date">{new Date(post.pub_date).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        <h1>{post.title}</h1>
        {post.description && <p class="desc">{post.description}</p>}
      </header>
      {post.hero_image && <img src={post.hero_image} alt={post.title} class="hero-img" />}
      <div class="content" set:html={contentHtml} />
    </article>
    <a href="/panel" class="back">← Volver al panel</a>
  </main>
</Base>

<style>
  .preview-bar {
    background: #fef9c3;
    border-bottom: 1px solid #fde047;
    padding: 0.6rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.85rem;
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .preview-badge { color: #854d0e; font-weight: 500; }
  .preview-actions { display: flex; gap: 0.75rem; }
  .btn-edit, .btn-live {
    font-size: 0.8rem;
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    border: 1px solid #fde047;
    color: #854d0e;
    transition: background 0.15s;
  }
  .btn-edit:hover, .btn-live:hover { background: #fde047; }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  article { padding: 3rem 0 4rem; }
  header { margin-bottom: 2rem; border-bottom: 1px solid var(--color-border); padding-bottom: 2rem; }
  .date { font-size: 0.875rem; color: var(--color-muted); margin-bottom: 1rem; }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .desc { color: var(--color-muted); font-size: 1.05rem; }
  .hero-img { width: 100%; height: 300px; object-fit: cover; margin-bottom: 2rem; border-radius: 4px; }
  .content { line-height: 1.8; }
  .content :global(h2) { font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; margin: 2.5rem 0 1rem; }
  .content :global(h3) { font-size: 1.15rem; font-weight: 500; margin: 2rem 0 0.75rem; }
  .content :global(strong), .content :global(b) { font-weight: 800 !important; color: #000; }
  .content :global(p) { margin-bottom: 1.5rem; }
  .content :global(a) { text-decoration: underline; text-underline-offset: 3px; }
  .content :global(ul), .content :global(ol) { padding-left: 1.5rem; margin-bottom: 1.5rem; }
  .content :global(li) { margin-bottom: 0.4rem; }
  .content :global(blockquote) {
    border-left: 3px solid var(--color-border);
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.25rem;
    color: var(--color-muted);
    font-style: italic;
  }
  .content :global(pre) {
    background: #f4f4f2;
    border-radius: 6px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }
  .content :global(code) { font-size: 0.875rem; background: #f4f4f2; padding: 0.15em 0.4em; border-radius: 3px; }
  .content :global(pre code) { background: none; padding: 0; }
  .content :global(img) { max-width: 100%; border-radius: 6px; margin: 1rem 0; }
  .back { font-size: 0.875rem; color: var(--color-muted); transition: color 0.2s; display: inline-block; margin-bottom: 2rem; }
  .back:hover { color: var(--color-text); }
</style>
