---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const proyectos = await getCollection('portfolio');
  return proyectos.map(p => ({ params: { id: p.id }, props: { proyecto: p } }));
}

const { proyecto } = Astro.props;
const { Content } = await render(proyecto);
---
<Base title={`${proyecto.data.title} — Aitor Sánchez`} description={proyecto.data.description}>
  <Header />
  <main>
    <article>
      <header>
        {proyecto.data.image && <img src={proyecto.data.image} alt={proyecto.data.title} class="hero-img" />}
        <h1>{proyecto.data.title}</h1>
        <p class="desc">{proyecto.data.description}</p>
        <div class="meta">
          {proyecto.data.url && <a href={proyecto.data.url} target="_blank" rel="noopener" class="link">Ver proyecto →</a>}
          {proyecto.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </header>
      <div class="content"><Content /></div>
    </article>
    <a href="/portfolio" class="back">← Volver al portfolio</a>
  </main>
  <Footer />
</Base>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  article { padding: 3rem 0 4rem; }
  .hero-img { width: 100%; height: 300px; object-fit: cover; margin-bottom: 2rem; }
  header { margin-bottom: 3rem; border-bottom: 1px solid var(--color-border); padding-bottom: 2rem; }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }
  .desc { color: var(--color-muted); font-size: 1.05rem; margin-bottom: 1rem; }
  .meta { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
  .link { font-size: 0.875rem; text-decoration: underline; text-underline-offset: 3px; }
  .tag { font-size: 0.75rem; padding: 0.2rem 0.6rem; border: 1px solid var(--color-border); color: var(--color-muted); }
  .content p { margin-bottom: 1.5rem; }
  .back { font-size: 0.875rem; color: var(--color-muted); transition: color 0.2s; }
  .back:hover { color: var(--color-text); }
</style>
