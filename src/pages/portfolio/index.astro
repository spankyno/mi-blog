---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const db = Astro.locals.runtime?.env?.DB;
let proyectos = [];

if (db) {
  const result = await db.prepare(
    `SELECT slug, title, description, image, tags FROM portfolio ORDER BY pub_date DESC`
  ).all();
  proyectos = result.results ?? [];
}
---
<Base title="Portfolio — Aitor Sánchez">
  <Header />
  <main>
    <h1>Portfolio</h1>
    <ul class="grid">
      {proyectos.map((p: any) => {
        const tags = JSON.parse(p.tags || '[]');
        return (
          <li>
            <a href={`/portfolio/${p.slug}`} class="card">
              {p.image && <img src={p.image} alt={p.title} />}
              <div class="card-body">
                <span class="card-title">{p.title}</span>
                <span class="card-desc">{p.description}</span>
                {tags.length > 0 && (
                  <div class="tags">
                    {tags.map((tag: string) => <span class="tag">{tag}</span>)}
                  </div>
                )}
              </div>
            </a>
          </li>
        );
      })}
      {proyectos.length === 0 && <li class="empty">Próximamente…</li>}
    </ul>
  </main>
  <Footer />
</Base>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    margin: 3rem 0 2.5rem;
  }
  .grid { list-style: none; display: flex; flex-direction: column; gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  .card {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--color-bg);
    transition: background 0.2s;
    align-items: flex-start;
  }
  .card:hover { background: #f0f0eb; }
  .card img { width: 80px; height: 80px; object-fit: cover; flex-shrink: 0; }
  .card-body { display: flex; flex-direction: column; gap: 0.35rem; }
  .card-title { font-weight: 500; }
  .card-desc { font-size: 0.9rem; color: var(--color-muted); }
  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.25rem; }
  .tag { font-size: 0.75rem; padding: 0.2rem 0.6rem; border: 1px solid var(--color-border); color: var(--color-muted); }
  .empty { padding: 1.25rem; color: var(--color-muted); }
</style>
