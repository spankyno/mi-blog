---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const { slug } = Astro.params;
const db = Astro.locals.runtime?.env?.DB;
let proyecto = null;

if (db) {
  const result = await db.prepare(
    `SELECT * FROM portfolio WHERE slug = ?`
  ).bind(slug).first();
  proyecto = result;
}

if (!proyecto) return Astro.redirect('/portfolio');

const tags = JSON.parse(proyecto.tags || '[]');
---
<Base title={`${proyecto.title} — Aitor Sánchez`} description={proyecto.description}>
  <Header />
  <main>
    <article>
      {proyecto.image && <img src={proyecto.image} alt={proyecto.title} class="hero-img" />}
      <header>
        <h1>{proyecto.title}</h1>
        <p class="desc">{proyecto.description}</p>
        <div class="meta">
          {proyecto.url && <a href={proyecto.url} target="_blank" rel="noopener" class="link">Ver proyecto →</a>}
          {tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      </header>
      <div class="content" set:html={proyecto.content} />
    </article>
    <a href="/portfolio" class="back">← Volver al portfolio</a>
  </main>
  <Footer />
</Base>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  article { padding: 3rem 0 4rem; }
  .hero-img { width: 100%; height: 300px; object-fit: cover; margin-bottom: 2rem; }
  header { margin-bottom: 3rem; border-bottom: 1px solid var(--color-border); padding-bottom: 2rem; }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }
  .desc { color: var(--color-muted); font-size: 1.05rem; margin-bottom: 1rem; }
  .meta { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
  .link { font-size: 0.875rem; text-decoration: underline; text-underline-offset: 3px; }
  .tag { font-size: 0.75rem; padding: 0.2rem 0.6rem; border: 1px solid var(--color-border); color: var(--color-muted); }
  .content :global(p) { margin-bottom: 1.5rem; line-height: 1.8; }
  .back { font-size: 0.875rem; color: var(--color-muted); transition: color 0.2s; }
  .back:hover { color: var(--color-text); }
</style>
